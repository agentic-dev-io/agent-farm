{
  "mcpServers": {
    "agent-farm": {
      "command": "agent-farm",
      "args": ["mcp"],
      "env": {}
    },
    "agent-farm-memory": {
      "command": "agent-farm",
      "args": ["mcp"],
      "env": {
        "DUCKDB_DATABASE": ".agent_memory.db"
      }
    },
    "agent-farm-http": {
      "command": "agent-farm",
      "args": ["mcp", "--http-port", "9999"],
      "env": {
        "DUCKDB_DATABASE": ":memory:"
      }
    }
  }
}
